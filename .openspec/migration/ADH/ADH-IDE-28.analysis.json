          "name": "repriseConfirmed",
          "type": "boolean",
          "source": "W0 reprise confirmee",
          "nullable": false
        }
      ]
    }
  ],
  "stateFields": [
    {
      "name": "merges",
      "type": "AccountMerge[]",
      "default": "[]"
    },
    {
      "name": "currentMerge",
      "type": "AccountMerge | null",
      "default": "null"
    },
    {
      "name": "mergeDetails",
      "type": "AccountMergeDetail[]",
      "default": "[]"
    },
    {
      "name": "mergeLogs",
      "type": "AccountMergeLog[]",
      "default": "[]"
    },
    {
      "name": "validation",
      "type": "MergeValidation | null",
      "default": "null"
    },
    {
      "name": "isLoading",
      "type": "boolean",
      "default": "false"
    },
    {
      "name": "error",
      "type": "string | null",
      "default": "null"
    },
    {
      "name": "processingStep",
      "type": "string | null",
      "default": "null"
    },
    {
      "name": "tablesProcessed",
      "type": "number",
      "default": "0"
    },
    {
      "name": "totalTables",
      "type": "number",
      "default": "60"
    }
  ],
  "actions": [
    {
      "name": "validateNetwork",
      "params": [],
      "businessRules": [
        "RM-001: Check that W0 reseau != 'R' (network not in restricted mode)",
        "If network validation fails, block the merge operation",
        "Update validation.networkStatus state field"
      ],
      "returns": "Promise<MergeValidation>"
    },
    {
      "name": "validateSession",
      "params": [],
      "businessRules": [
        "RM-002: Check that W0 validation = 'V' (session is valid)",
        "RM-003: Check that W0 validation != blocked state",
        "Verify no active closure process (cloture en cours)",
        "Update validation.sessionClosed state field"
      ],
      "returns": "Promise<MergeValidation>"
    },
    {
      "name": "initiateMerge",
      "params": [
        "sourceSociete: string",
        "sourceCompte: string",
        "sourceFiliation: number",
        "targetSociete: string",
        "targetCompte: string",
        "targetFiliation: number"
      ],
      "businessRules": [
        "RM-004: Set W0 chrono histo = 'F' for fusion operation",
        "RM-010: Check condition ([BK]=6 OR P0 Reprise Auto)",
        "Create initial record in histo_fusionseparation table",
        "Write initial log entry via writeLog action",
        "Set status to 'PROCESSING'",
        "Update currentMerge state field"
      ],
      "returns": "Promise<AccountMerge>"
    },
    {
      "name": "processTableMerge",
      "params": [
        "mergeId: number",
        "tableCode: string"
      ],
      "businessRules": [
        "Process merge for specific table (prestations, comptable, change, depot_garantie, etc.)",
        "Read source account records from specified table",
        "Update records to point to target account",
        "Write detail record to histo_fusionseparation_det",
        "Count records processed and errors",
        "Increment tablesProcessed state field",
        "Update processingStep with current table name"
      ],
      "returns": "Promise<AccountMergeDetail>"
    },
    {
      "name": "writeLog",
      "params": [
        "mergeId: number",
        "logType: 'INFO' | 'WARNING' | 'ERROR'",
        "message: string"
      ],
      "businessRules": [
        "RM-006: Verify W0 code LOG existe before writing",
        "Write log entry to histo_fusionseparation_log (13 calls in original program)",
        "Include timestamp, merge ID, log type, and message",
        "Append to mergeLogs state array"
      ],
      "returns": "Promise<AccountMergeLog>"
    },
    {
      "name": "confirmMerge",
      "params": [
        "mergeId: number"
      ],
      "businessRules": [
        "RM-007: Validate W0 Filiation garantie conditions",
        "RM-008: Check W0 reprise confirmee flag",
        "RM-009: Verify W0 Compte remplace validation",
        "RM-011: Set reprise confirmee flag to true",
        "Update merge status to 'COMPLETED'",
        "Write final log entries",
        "Call deleteTempData to clean up temporary records"
      ],
      "returns": "Promise<AccountMerge>"
    },
    {
      "name": "rollbackMerge",
      "params": [
        "mergeId: number",
        "reason: string"
      ],
      "businessRules": [
        "Revert all table changes (60 tables affected)",
        "Update merge status to 'FAILED'",
        "Write error logs with rollback details",
        "Restore source account records",
        "Clean up partial merge data"
      ],
      "returns": "Promise<void>"
    },
    {
      "name": "printMergeTicket",
      "params": [
        "mergeId: number"
      ],
      "businessRules": [
        "RM-012: Skip if P0.Sans interface = true (no UI mode)",
        "Generate merge ticket document (callee 36: Print Separation ou fusion)",
        "Include source and target account details",
        "List all tables merged with record counts",
        "Show merge timestamp and operator",
        "Web version: generate PDF instead of print to legacy printer"
      ],
      "returns": "Promise<Blob>"
    },
    {
      "name": "deleteTempData",
      "params": [
        "mergeId: number"
      ],
      "businessRules": [
        "Delete records from histo_fusionseparation_saisie (callee 33: 2 calls)",
        "Clean up temporary merge data",
        "Only execute after successful merge confirmation",
        "Write log entry confirming cleanup"
      ],
      "returns": "Promise<void>"
    },
    {
      "name": "fetchMergeHistory",
      "params": [
        "societe?: string",
        "compte?: string",
        "filiation?: number",
        "startDate?: Date",
        "endDate?: Date"
      ],
      "businessRules": [
        "Query histo_fusionseparation with optional filters",
        "Include related details and logs",
        "Sort by merge date descending",
        "Update merges state array"
      ],
      "returns": "Promise<AccountMerge[]>"
    }
  ],
  "apiEndpoints": [
    {
      "method": "GET",
      "path": "/api/accountMerge/list",
      "queryParams": [
        "societe?",
        "compte?",
        "filiation?",
        "startDate?",
        "endDate?",
        "status?"
      ],
      "response": "AccountMerge[]"
    },
    {
      "method": "GET",
      "path": "/api/accountMerge/:id",
      "queryParams": [],
      "response": "AccountMerge"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/validate",
      "queryParams": [],
      "response": "MergeValidation"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/initiate",
      "queryParams": [],
      "response": "AccountMerge"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/:id/process/:tableCode",
      "queryParams": [],
      "response": "AccountMergeDetail"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/:id/confirm",
      "queryParams": [],
      "response": "AccountMerge"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/:id/rollback",
      "queryParams": [],
      "response": "void"
    },
    {
      "method": "GET",
      "path": "/api/accountMerge/:id/logs",
      "queryParams": [],
      "response": "AccountMergeLog[]"
    },
    {
      "method": "GET",
      "path": "/api/accountMerge/:id/details",
      "queryParams": [],
      "response": "AccountMergeDetail[]"
    },
    {
      "method": "POST",
      "path": "/api/accountMerge/:id/print",
      "queryParams": [],
      "response": "Blob"
    }
  ],
