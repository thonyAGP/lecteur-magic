      "name": "MergeValidation",
      "fields": [
        {
          "name": "networkStatus",
          "type": "boolean",
          "source": "W0 reseau != 'R'",
          "nullable": false
        },
        {
          "name": "sessionClosed",
          "type": "boolean",
          "source": "W0 validation != 'V'",
          "nullable": false
        },
